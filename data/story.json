                "speaker": "Rin",
                "text": "I doesn't have any plan yet. But I bet there will be a lot of interesting there!"
            },
            {
                "speaker": "{player}",
                "text": "Yeah, me too!!",
                "characters": [{
                    "name": "Rin", "position": "left", "expression": "delighted"
                },{
                    "name": "Player", "position": "right", "expression": "laugh"
                }]
